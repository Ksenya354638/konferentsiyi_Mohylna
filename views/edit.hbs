<div class="container" style="min-height: 50vh">
    <div class="row">
        <div class="col-6 text-center mx-auto">
            <h2 class="text-primary">
            Кафедра "{{kafedry.nazva_kafedry}}" (редагування)
            </h2>
            <form action="/edit" method="post">
                <input type="hidden" name="id_kafedry" value="{{kafedry.id_kafedry}}">
                <div class="form-group">
                    <label>Назва кафедри</label>
                    <input type="text" class="form-control" 
                        name="nazva_kafedry"
                        value="{{kafedry.nazva_kafedry}}">
                </div>
                <div class="form-group">
                    <label>Розташування</label>
                        <input type="text" class="form-control"
                            name="roztashuvannya"
                            value="{{kafedry.roztashuvannya}}">
                </div>
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <button type="reset" class="btn btn-primary">Очистити</button>
            </form>
        </div>
    </div>
</div>