<div class="container">
    <h2 class="text-primary text-center">Редагувати співробітника</h2>
    <form method="POST" action="/spivrobitnyky_edit">
        <input type="hidden" name="id_spivrobitnyky"
        value="{{spivrobitnyky.id_spivrobitnyky}}">
        <div class="form-group">
            <label>Прізвище</label>
            <input type="text" name="prizvyshche"
            value="{{spivrobitnyky.prizvyshche}}" class="form-control">
        </div>
        <div class="form-group">
            <label>Ім’я</label>
            <input type="text" name="imya"
            value="{{spivrobitnyky.imya}}" class="form-control">
        </div>
        <div class="form-group">
            <label>По батькові</label>
            <input type="text" name="pobatkovi"
            value="{{spivrobitnyky.pobatkovi}}" class="form-control">
        </div>
        <div class="form-group">
            <label>Кафедра</label>
            <select name="id_kafedry" class="form-control">
                {{#each kafedry}}
                    <option value="{{this.id_kafedry}}">
                        {{this.nazva_kafedry}}
                    </option>
                {{/each}}
            </select>
        </div>
        <button type="submit" class="btn btn-success mt-2">
            Зберегти
        </button>
    </form>
</div>

