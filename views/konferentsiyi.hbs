<div class="container">
    <h1 class="text-center text-primary">Конференції</h1>
    <div class="row">
        <div class="col-12">
            {{#if konferentsiyi_visible}}
                <div class="text-right">
                    <a href="/konferentsiyi_create" class="btn btn-primary btn-sm my-2">Додати запис</a>
                </div>
                <div class="row">
                    {{#each konferentsiyi}}
                        <div class="card text-center col-md-6">
                            <div class="card-header">
                                Код конференції: <b>{{this.id_conferentsiyi}}</b>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">{{this.nazva_conferentsiyi}}</h5>
                                <p class="card-text">
                                    Відповідальний: <b>{{this.prizvyshche}}</b>
                                </p>
                                <p class="card-text">
                                    {{this.data_pochatku}} - {{this.data_zakinchennya}}
                                </p>
                                <p class="card-text">
                                    Тривалість: <b>{{this.truvalist}} дн.</b>
                                </p>
                            </div>
                            <div class="card-footer">
                                <form action="/konferentsiyi_delete/{{this.id_conferentsiyi}}" method="POST" style="display:inline;">
                                    <input type="submit" value="Видалити" class="btn btn-warning btn-sm"/>
                                </form>
                                <a href="/konferentsiyi_edit/{{this.id_conferentsiyi}}" class="btn btn-success btn-sm">
                                    Редагувати
                                </a>
                            </div>
                        </div>
                    {{/each}}
                </div>
            {{else}}
                <form method="post" class="form-inline my-2">
                    <div class="form-group mx-auto">
                        <div class="form-group">
                            <label>З</label>
                            <input type="date" class="form-control mx-2" name="data_pochatku">
                        </div>
                        <div class="form-group">
                            <label>По</label>
                            <input type="date" class="form-control mx-2" name="data_zakinchennya">
                        </div>
                        <button type="submit" class="btn btn-primary">
                            Показати
                        </button>
                    </div>
                </form>
            {{/if}}
        </div>
    </div>
</div>