<div class="container-fluid" style="min-height: 50vh">
    <div class="row mb-3">
        <div class="col-12 text-center">
            <h2 class="text-primary">Топ 10 місць проживання за кількістю учасників</h2>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <thead class="table-primary text-center">
                <tr>
                    <th>#</th>
                    <th>Місце проживання</th>
                    <th>Кількість учасників</th>
                </tr>
            </thead>
            <tbody>
                {{#each misce_top}}
                <tr class="text-center">
                    <td>{{@index}}</td>
                    <td>{{this.misce}}</td>
                    <td>{{this.kilkist}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>