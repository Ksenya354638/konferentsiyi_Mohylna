<div class="container-fluid" style="min-height: 50vh">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="text-primary">Кафедри</h1>
        </div>
    </div>

    <div class="text-right">
        <a href="/create" class="btn btn-primary btn-sm my-2">Додати запис</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <tbody>
                <tr class="text-dark table-primary">
                    <th></th>
                    <th></th>
                    <th>Код кафедри</th>
                    <th>Назва</th>
                    <th>Розташування</th>
                </tr>

                {{#each kafedry}}
                <tr>
                    <td>
                        <form action="/delete/{{this.id_kafedry}}" method="POST">
                            <input type="submit" value="Видалити" class="btn btn-warning btn-sm"/>
                        </form>
                    </td>
                    <td>
                        <a href="/edit/{{this.id_kafedry}}" class="btn btn-success btn-sm">Редагувати</a>
                    </td>
                    <td>{{this.id_kafedry}}</td>
                    <td>{{this.nazva_kafedry}}</td>
                    <td>{{this.roztashuvannya}}</td>
                </tr>
                {{/each}}

            </tbody>
        </table>
    </div>
</div>