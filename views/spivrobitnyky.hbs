<div class="container-fluid" style="min-height: 50vh">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="text-primary">Співробітники</h1>
            {{#if spivrobitnyky_visible}}
                <div class="text-right">
                    <a href="/spivrobitnyky_create" class="btn btn-primary btn-sm my-2">Додати запис</a>
                </div>
                <div class="row">
                    {{#each spivrobitnyky}}
                    <div class="card text-center col-md-3 m-2">
                        <div class="card-header">Код співробітника {{this.id_spivrobitnyky}}</div>
                            <div class="card-body">
                                <h5 class="card-title">{{this.prizvyshche}}</h5>
                                <p class="card-text">{{this.imya}} {{this.pobatkovi}}</p>
                            </div>
                            <div class="card-footer text-muted">
                                <form action="/spivrobitnyky_delete/{{this.id_spivrobitnyky}}" method="POST" style="display:inline;">
                                    <input type="submit" value="Видалити" class="btn btn-warning btn-sm"/>
                                </form>
                                <a href="/spivrobitnyky_edit/{{this.id_spivrobitnyky}}" class="btn bg-success btn-sm">Редагувати</a>
                            </div>
                    </div>
                    {{/each}}
                </div>
            {{else}}
                <div class="col-6 text-center mx-auto">
                    <form method="post" class="form-inline">
                        <div class="form-group mx-auto">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">За кафедрою</span>
                                </div>
                                <input list="id" class="form-control" name="nazva_kafedry"
                                    placeholder="Виберіть кафедру" autocomplete="off">
                                    <datalist id="id">
                                        {{#each spivrobitnyky}}
                                            <option value="{{this.nazva_kafedry}}"></option>
                                        {{/each}}
                                    </datalist>
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary mx-1 my-2">Показати</button>
                        </div>
                    </form>
                </div>
            {{/if}}
        </div>
    </div>
</div>